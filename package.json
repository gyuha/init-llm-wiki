{
  "name": "init-llm-wiki",
  "version": "0.1.2",
  "description": "Scaffold an LLM-maintained personal wiki powered by Claude",
  "type": "module",
  "bin": {
    "init-llm-wiki": "bin/install.js"
  },
  "files": [
    "bin/",
    "wiki/"
  ],
  "scripts": {
    "prepublishOnly": "node bin/install.js test-publish && rm -rf test-publish",
    "publish:patch": "npm version patch && npm publish",
    "publish:minor": "npm version minor && npm publish",
    "publish:major": "npm version major && npm publish",
    "publish:dry": "npm publish --dry-run",
    "test": "node bin/install.js test-wiki && rm -rf test-wiki"
  },
  "engines": {
    "node": ">=16"
  },
  "keywords": [
    "llm",
    "wiki",
    "claude",
    "knowledge-base"
  ],
  "license": "MIT"
}
